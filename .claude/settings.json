{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "plansDirectory": "docs/plans",
  "permissions": {
    "deny": [
      "Edit(docs/index.html)",
      "Write(docs/index.html)",
      "Edit(docs/plans/index.html)",
      "Write(docs/plans/index.html)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/claude/session-context.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/claude/guard.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/rebuild-index.mjs\""
          }
        ]
      }
    ]
  }
}
