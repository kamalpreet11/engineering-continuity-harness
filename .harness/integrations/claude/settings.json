{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "plansDirectory": "docs/plans",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git tag *)",
      "Bash(git stash *)",
      "Bash(git branch -d *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm publish *)",
      "Bash(npm ci*)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(curl -X *)",
      "Bash(curl -d *)",
      "Bash(curl --data*)",
      "Bash(wget *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(sudo rm *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -df*)",
      "Bash(git clean -xfd*)",
      "Bash(git clean -fdx*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Edit(docs/index.html)",
      "Write(docs/index.html)",
      "Edit(docs/plans/index.html)",
      "Write(docs/plans/index.html)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/claude/session-context.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/claude/guard.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.harness/bin/hooks/rebuild-index.mjs\""
          }
        ]
      }
    ]
  }
}
