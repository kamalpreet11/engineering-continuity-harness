{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .harness/bin/hooks/antigravity/guard.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .harness/bin/hooks/rebuild-index.mjs"
          }
        ]
      }
    ]
  }
}
